#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
TARGET_SCRIPT="$SCRIPT_DIR/../../scientific-writing/scripts/crossref_validator.py"

if [[ ! -f "$TARGET_SCRIPT" ]]; then
    echo "Missing Crossref validator: $TARGET_SCRIPT" >&2
    exit 1
fi

exec python3 "$TARGET_SCRIPT" "$@"
